  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "cron/**/*", "server.ts", "tests/**/*"],
  "exclude": ["node_modules", "dist", "public"]
}
