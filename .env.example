DATABASE_URL=postgresql://...

# LINE
LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=        # from LINE Developers console → Messaging API channel → Channel secret

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=    # any random string — set same value in setWebhook call

# AI
GROQ_API_KEY=
NVIDIA_API_KEY=           # optional primary; Groq is fallback if omitted
CRYPTOPANIC_TOKEN=        # optional; enables crypto news sentiment in cross alerts (https://cryptopanic.com/developers/api/)

# App
APP_URL=https://your-app.onrender.com
INTERNAL_SECRET=        # random secret for cron → /internal/* endpoints
PORT=3000
