DATABASE_URL=postgresql://...

# LINE
LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=        # from LINE Developers console → Messaging API channel → Channel secret

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=    # any random string — set same value in setWebhook call

# AI
GROQ_API_KEY=             # free at console.groq.com
NVIDIA_API_KEY=           # optional; higher quality (integrate.api.nvidia.com)
OPENROUTER_API_KEY=       # optional third fallback; free models at openrouter.ai

# App
APP_URL=https://your-app.onrender.com
INTERNAL_SECRET=        # random secret for cron → /internal/* endpoints
PORT=3000
